{
  "name": "rd-advance-boutique",
  "version": "1.0.0",
  "description": "GitHub Pages compatible static website for RD Advance Boutique.",
  "main": "index.html",
  "scripts": {
    "start": "node server.js",
    "check": "find . -path './node_modules' -prune -o -path './.git' -prune -o -name '*.js' -print0 | xargs -0 -n1 node --check"
  },
  "keywords": [
    "static-site",
    "github-pages",
    "boutique",
    "whatsapp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "serve": "^14.2.3"
  }
}
